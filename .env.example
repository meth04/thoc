# Sao chép file này thành `.env` rồi điền key thật. `.env` đã nằm trong .gitignore.
# Loader đọc file này TRỰC TIẾP bằng regex nên tên biến có gạch ngang vẫn hoạt động;
# viết GEMINI_API_KEY_1 (gạch dưới) cũng được.

# mock | real  (mặc định mock — KHÔNG đổi sang real trước HUMAN-GATE 1)
LLM_MODE=mock

# ---- AI Studio (Gemma + gemini-3.1-flash-lite) ----
GEMINI-API-KEY-1=dien_key_1
GEMINI-API-KEY-2=dien_key_2
GEMINI-API-KEY-3=dien_key_3
GEMINI-API-KEY-4=dien_key_4
GEMINI-API-KEY-5=dien_key_5
GEMINI-API-KEY-6=dien_key_6
GEMINI-API-KEY-7=dien_key_7
GEMINI-API-KEY-8=dien_key_8

# ---- 9router (OpenAI-compatible, tự xoay 3 tài khoản Gemini CLI phía sau) ----
NINE_ROUTER_BASE_URL=http://localhost:8000/v1
NINE_ROUTER_API_KEY=dien_key_9router
# ⚠️ kiểm tra lại cổng/đường dẫn thật của 9router trên máy bạn (vd /v1)
